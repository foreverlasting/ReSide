{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReSide",
  "version": "0.4.0",
  "identifier": "dev.reside.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ReSide",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "linux": {
      "deb": {
        "depends": ["usbmuxd", "libimobiledevice", "webkit2gtk-4.1", "libnotify", "libayatana-appindicator3-1"]
      }
    }
  }
}
